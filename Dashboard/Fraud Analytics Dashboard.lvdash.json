{
  "datasets": [
    {
      "name": "910e11c0",
      "displayName": "fraud_location",
      "queryLines": [
        "SELECT location, fraud_count, fraud_rate_pct, total_transactions\r\n",
        "FROM fraud_analytics.gold.fraud_by_location\r\n",
        "ORDER BY fraud_count DESC\r\n",
        "LIMIT 10"
      ]
    },
    {
      "name": "11e04bb3",
      "displayName": "fraud_monthly_trend",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  fraud_by_month\n",
        "ORDER BY\n",
        "  transaction_year,\n",
        "  transaction_month"
      ],
      "columns": [
        {
          "displayName": "Month Label",
          "expression": "CONCAT(CAST(`transaction_year` AS STRING), '-', LPAD(CAST(`transaction_month` AS STRING), 2, '0'))"
        }
      ],
      "catalog": "fraud_analytics",
      "schema": "gold"
    },
    {
      "name": "7a5e8cff",
      "displayName": "fraud_by_transaction_type",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  fraud_by_transaction_type"
      ],
      "catalog": "fraud_analytics",
      "schema": "gold"
    },
    {
      "name": "b3af8a42",
      "displayName": "fraud_by_merchant",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  fraud_by_merchant\n",
        "ORDER BY\n",
        "  fraud_count DESC\n",
        "LIMIT 10"
      ],
      "columns": [
        {
          "displayName": "Merchant Label",
          "expression": "CONCAT('Merchant ', CAST(`merchant_id` AS STRING))"
        }
      ],
      "catalog": "fraud_analytics",
      "schema": "gold"
    }
  ],
